---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';

const allSections = await getCollection('sections');
const sorted = allSections.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sorted.map(async (section) => {
    const { Content } = await section.render();
    return {
      id: section.slug,
      title: section.data.title,
      Content,
    };
  })
);

const tocItems = rendered.map(({ id, title }) => ({ id, title }));
---

<BaseLayout
  title="State of State Management"
  description="The rise of graph-based state management across Web, iOS, and Android — Push-based vs Graph-based paradigms in 2026."
>
  <Header />

  <div class="max-w-5xl mx-auto px-5 sm:px-6">
    <div class="lg:grid lg:grid-cols-[180px_1fr] lg:gap-16">
      <!-- Sidebar ToC (desktop) -->
      <aside class="hidden lg:block">
        <TableOfContents sections={tocItems} />
      </aside>

      <!-- Main content -->
      <main class="min-w-0 max-w-2xl">
        <!-- Mobile ToC -->
        <details class="lg:hidden mb-10 group">
          <summary class="text-[13px] font-medium text-neutral-400 dark:text-neutral-500 cursor-pointer hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors">
            Table of Contents
          </summary>
          <ul class="mt-3 space-y-1 pl-0">
            {tocItems.map(({ id, title }) => (
              <li class="list-none">
                <a href={`#${id}`} class="block py-1 text-[13px] text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-200 transition-colors">
                  {title}
                </a>
              </li>
            ))}
          </ul>
        </details>

        <!-- Article sections -->
        <article>
          {rendered.map(({ id, title, Content }, i) => (
            <section id={id} class:list={["pb-14", i > 0 && "pt-14 border-t border-neutral-100 dark:border-neutral-800/60"]}>
              <h2 class="text-xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100 mb-6">
                {title}
              </h2>
              <div class="prose prose-neutral dark:prose-invert prose-sm max-w-none
                prose-headings:font-medium prose-headings:tracking-tight prose-headings:scroll-mt-8
                prose-h3:text-base prose-h3:mt-8 prose-h3:mb-3
                prose-h4:text-sm prose-h4:mt-6 prose-h4:mb-2 prose-h4:font-semibold
                prose-p:leading-relaxed prose-p:text-neutral-600 dark:prose-p:text-neutral-400
                prose-li:text-neutral-600 dark:prose-li:text-neutral-400
                prose-strong:text-neutral-700 dark:prose-strong:text-neutral-300 prose-strong:font-medium
                prose-a:text-neutral-900 dark:prose-a:text-neutral-200 prose-a:underline prose-a:decoration-neutral-300 dark:prose-a:decoration-neutral-700 prose-a:underline-offset-2 hover:prose-a:decoration-neutral-500
                prose-code:before:content-none prose-code:after:content-none
                prose-code:text-[13px] prose-code:font-normal prose-code:bg-neutral-100 dark:prose-code:bg-neutral-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md
                prose-pre:bg-neutral-950 prose-pre:rounded-lg prose-pre:border prose-pre:border-neutral-800
                prose-hr:border-neutral-100 dark:prose-hr:border-neutral-800/60">
                <Content />
              </div>
            </section>
          ))}
        </article>
      </main>
    </div>
  </div>

  <Footer />
</BaseLayout>
