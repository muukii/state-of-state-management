---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';

const allSections = await getCollection('sections');
const sorted = allSections.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sorted.map(async (section) => {
    const { Content } = await section.render();
    return {
      id: section.slug,
      title: section.data.title,
      Content,
    };
  })
);

const tocItems = rendered.map(({ id, title }) => ({ id, title }));
---

<BaseLayout
  title="State of State Management"
  description="The rise of graph-based state management across Web, iOS, and Android."
>
  <TableOfContents sections={tocItems} />
  <Header />

  <div class="lg:ml-[200px]">
    <main class="max-w-2xl mx-auto px-6">
      <!-- Mobile ToC -->
      <details class="lg:hidden mb-10">
        <summary class="text-[13px] font-medium text-neutral-400 dark:text-neutral-500 cursor-pointer hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors">
          Contents
        </summary>
        <ul class="mt-3 space-y-1">
          {tocItems.map(({ id, title }) => (
            <li>
              <a href={`#${id}`} class="block py-1.5 text-[13px] text-neutral-400 dark:text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-200 transition-colors">
                {title}
              </a>
            </li>
          ))}
        </ul>
      </details>

      <!-- Article sections -->
      <article>
        {rendered.map(({ id, title, Content }, i) => (
          <>
            {i > 0 && <div class="section-divider" />}
            <section id={id}>
              <h2 class="text-xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100 mb-6">
                {title}
              </h2>
              <div class="prose prose-neutral dark:prose-invert prose-base max-w-none
                prose-headings:font-semibold prose-headings:tracking-tight prose-headings:scroll-mt-20
                prose-h3:text-[17px] prose-h3:mt-10 prose-h3:mb-4
                prose-h4:text-[15px] prose-h4:mt-8 prose-h4:mb-3
                prose-p:leading-[1.8] prose-p:text-neutral-500 dark:prose-p:text-neutral-400
                prose-li:text-neutral-500 dark:prose-li:text-neutral-400 prose-li:leading-[1.8]
                prose-strong:text-neutral-700 dark:prose-strong:text-neutral-300 prose-strong:font-semibold
                prose-a:text-neutral-900 dark:prose-a:text-neutral-200 prose-a:underline prose-a:decoration-neutral-200 dark:prose-a:decoration-neutral-700 prose-a:underline-offset-[3px] hover:prose-a:decoration-neutral-400
                prose-code:before:content-none prose-code:after:content-none
                prose-code:text-[13px] prose-code:font-normal prose-code:text-neutral-600 dark:prose-code:text-neutral-300 prose-code:bg-neutral-100 dark:prose-code:bg-neutral-800/80 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:border prose-code:border-neutral-200/80 dark:prose-code:border-neutral-700/50
                prose-pre:rounded-xl prose-pre:border prose-pre:border-neutral-200/60 dark:prose-pre:border-neutral-800/60
                prose-hr:hidden
                prose-ul:my-4 prose-ol:my-4">
                <Content />
              </div>
            </section>
          </>
        ))}
      </article>
    </main>
  </div>

  <Footer />
</BaseLayout>
