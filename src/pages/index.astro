---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SidebarNav from '../components/SidebarNav.astro';
import TocRail from '../components/TocRail.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import Mermaid from '../components/Mermaid.astro';
import Separator from '../components/ui/Separator.astro';
import Card from '../components/ui/Card.astro';
import CardHeader from '../components/ui/CardHeader.astro';
import CardTitle from '../components/ui/CardTitle.astro';
import CardContent from '../components/ui/CardContent.astro';

const allSections = await getCollection('sections');
const sorted = allSections.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sorted.map(async (section) => {
    const { Content } = await section.render();
    return {
      id: section.slug,
      title: section.data.title,
      Content,
    };
  })
);

const tocItems = rendered.map(({ id, title }) => ({ id, title }));
---

<BaseLayout
  title="State of State Management"
  description="The rise of graph-based state management across Web, iOS, and Android."
>
  <SiteHeader />

  <div class="mx-auto flex max-w-screen-2xl gap-8 px-4 sm:px-6 lg:px-8">
    <SidebarNav sections={tocItems} />

    <main class="min-w-0 flex-1 py-10 lg:py-14">
      <div class="mx-auto max-w-3xl">
        <Hero />

        <details class="lg:hidden mb-10 rounded-lg border border-border p-4">
          <summary class="cursor-pointer text-sm font-medium text-foreground">
            Contents
          </summary>
          <ul class="mt-3 flex flex-col gap-1">
            {tocItems.map(({ id, title }) => (
              <li>
                <a
                  href={`#${id}`}
                  class="block rounded-md px-2 py-1.5 text-sm text-muted-foreground hover:bg-accent hover:text-foreground transition-colors"
                >
                  {title}
                </a>
              </li>
            ))}
          </ul>
        </details>

        <article class="prose dark:prose-invert max-w-none
          prose-headings:scroll-mt-20 prose-headings:tracking-tight
          prose-h2:text-2xl prose-h2:font-semibold prose-h2:mt-0 prose-h2:mb-6
          prose-h3:text-lg prose-h3:font-semibold prose-h3:mt-10 prose-h3:mb-4
          prose-h4:text-base prose-h4:font-semibold prose-h4:mt-8 prose-h4:mb-3
          prose-p:leading-7
          prose-li:leading-7
          prose-a:underline prose-a:underline-offset-4 prose-a:decoration-border hover:prose-a:decoration-foreground
          prose-code:rounded prose-code:border prose-code:border-border prose-code:bg-muted prose-code:px-1.5 prose-code:py-0.5 prose-code:text-[0.85em] prose-code:font-normal prose-code:before:content-none prose-code:after:content-none
          prose-pre:rounded-lg prose-pre:border prose-pre:border-border
          [&_pre_code]:border-0 [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:rounded-none [&_pre_code]:text-[inherit]
          prose-hr:hidden
          prose-ul:my-4 prose-ol:my-4
          prose-strong:font-semibold">
          {rendered.map(({ id, title, Content }, i) => (
            <>
              {i > 0 && <Separator class="my-12 not-prose" />}
              <section id={id} class="scroll-mt-20">
                <h2>{title}</h2>
                <Content />

                {id === '02-push-vs-graph' && (
                  <div class="not-prose mt-10 grid grid-cols-1 gap-4 md:grid-cols-2">
                    <Card>
                      <CardHeader>
                        <CardTitle class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
                          Push-based
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <Mermaid chart={`
graph TD
  Store["🔄 Store"]
  Store -->|notify| SubA["Sub A"]
  Store -->|notify| SubB["Sub B"]
  Store -->|notify| SubC["Sub C"]
  SubA -->|"selector ✓"| RenderA["re-render"]
  SubB -->|"selector ✗"| Skip["skip"]
  SubC -->|"selector ✓"| RenderC["re-render"]
`} />
                      </CardContent>
                    </Card>
                    <Card>
                      <CardHeader>
                        <CardTitle class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
                          Graph-based
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <Mermaid chart={`
graph TD
  Count["count ●"]
  User["user"]
  Count --> Doubled["doubled"]
  Count --> Filtered["filtered"]
  User -.-> Greeting["greeting"]
  Doubled --> RenderA["re-render"]
  Filtered --> RenderB["re-render"]
`} />
                      </CardContent>
                    </Card>
                  </div>
                )}
              </section>
            </>
          ))}
        </article>
      </div>
    </main>

    <TocRail sections={tocItems} />
  </div>

  <Footer />
</BaseLayout>
