---
import DocsLayout from '../layouts/DocsLayout.astro';
import { Code } from 'astro:components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const twoKindsCode = `// Everything is one of these two:

// 1. Stored — holds a concrete value
let a = Node(stored: 1)
let b = Node(stored: 2)

// 2. Computed — derives from others
let c = Node(rule: { a.value + b.value })`;

const excelCode = `// An app's entire state can be modeled as a spreadsheet:
//
//   A1: 100        ← stored (user input)
//   A2: 200        ← stored (API response)
//   A3: =A1+A2     ← computed (derived)
//   A4: =A3*0.1    ← computed (derived from derived)
//
// Excel already solved this in the 1980s.
// The question is: how does the engine know
// that changing A1 should update A3 and A4?`;

const captureNaiveCode = `// Without automatic capture, you must wire dependencies manually:

let a = Store(value: 1)
let b = Store(value: 2)

// Manually register: "c depends on a and b"
a.subscribers.append(c)
b.subscribers.append(c)

// For every new dependency, you add another line.
// For conditional dependencies, you manage subscribe/unsubscribe yourself.
// This is exactly what RxSwift/Combine's combineLatest does.`;

const captureAutoCode = `// With automatic capture (ambient pattern):

let a = Node(stored: 1)
let b = Node(stored: 2)

// Just write the computation. Dependencies are discovered at runtime.
let c = Node(rule: { a.value + b.value })

// No manual wiring. No subscribe calls.
// When c.value is first accessed, the system discovers
// that c depends on a and b — automatically.`;

const captureStackCode = `// How the stack-based capture works internally:

// 1. Someone accesses c.wrappedValue
// 2. System sets currentNode = c
// 3. The rule closure executes: { a.value + b.value }
// 4. Inside a.value getter:
//    - checks currentNode → it's c
//    - creates edge: a → c (outgoing)
//    - creates edge: c ← a (incoming)
//    - returns the stored value
// 5. Same happens for b.value
// 6. The closure completes, returns a + b
// 7. System restores currentNode to previous (nil)
//
// Result: edges a→c and b→c now exist in the graph.`;

const captureNestedCode = `// Nested computed values use a stack:

let a = Node(stored: 1)
let b = Node(stored: 2)
let c = Node(rule: { a.value + b.value })  // depends on a, b
let e = Node(rule: { c.value * 10 })       // depends on c

// When e.wrappedValue is accessed:
//
// Stack: [nil]
// → push e → Stack: [e]
//   → e's rule calls c.value
//   → push c → Stack: [e, c]
//     → c's rule calls a.value → edge a→c created
//     → c's rule calls b.value → edge b→c created
//   → pop c → Stack: [e]
//   → edge c→e created
// → pop e → Stack: [nil]
//
// The stack ensures nested computeds work correctly.`;

const conditionalCode = `// Dependencies can change based on runtime conditions:

let useAlternate = Node(stored: false)
let a = Node(stored: 1)
let b = Node(stored: 2)
let d = Node(stored: 99)

let c = Node(rule: {
  if useAlternate.value {
    return d.value          // depends on: useAlternate, d
  } else {
    return a.value + b.value // depends on: useAlternate, a, b
  }
})

// First access: useAlternate is false
//   → dependencies: {useAlternate, a, b}
//   → d is NOT a dependency (never accessed)
//
// If useAlternate becomes true, c is recomputed:
//   → OLD dependencies cleared
//   → NEW dependencies: {useAlternate, d}
//   → a and b are no longer dependencies
//
// This is why dependencies are rebuilt on every evaluation.`;

const swiftuiBodyCode = `struct MyView: View {
  @State var count = 0
  @State var name = ""

  var body: some View {
    // This closure IS a computed node.
    // Only what you ACCESS becomes a dependency.

    Text("Count: \\(count)")
    // → body depends on count
    // → body does NOT depend on name
    // → changing name will NOT re-evaluate body
  }
}

// If the code were:
//   if showName {
//     Text(name)    // name accessed → dependency
//   } else {
//     Text("\\(count)")  // only count accessed
//   }
// → dependencies change based on which branch executes`;

const dirtyFlagCode = `// When a stored value changes:

a.value = 10  // a changed!

// Push approach (RxSwift/Combine):
//   → immediately recompute c = a + b = 10 + 2 = 12
//   → immediately push 12 to all of c's subscribers
//   → immediately recompute e = c * 10 = 120
//   → ...cascade continues synchronously

// Pull approach (AttributedGraph / swift-state-graph):
//   → mark c as "potentially dirty"
//   → mark e as "potentially dirty"
//   → STOP. No computation happens.
//   →
//   → ...later, when someone accesses e.value:
//   →   check: is e dirty? yes
//   →   check: is c dirty? yes
//   →   recompute c = 10 + 2 = 12
//   →   recompute e = 12 * 10 = 120
//   →   clear dirty flags`;

const setNeedsLayoutCode = `// UIKit's setNeedsLayout is the SAME pattern:

view.setNeedsLayout()   // = "mark as dirty"
// ...nothing happens yet...
// ...more mutations can accumulate...
view.layoutIfNeeded()   // = "recompute if dirty"

// Why are they TWO separate methods?
// Because batching.
//
// frame = newFrame      → setNeedsLayout()
// text = newText        → setNeedsLayout()
// color = newColor      → setNeedsLayout()
//
// Event loop tick → layoutIfNeeded() called once
// → single layout pass for all three changes
//
// If layout happened immediately on every mutation,
// you'd get 3 layout passes instead of 1.`;
---

<DocsLayout title="How Dependency Capture Works" currentPath={`${base}/internals/`}>
  <h1>How Dependency Capture Works</h1>
  <p class="text-lg text-muted-foreground !mt-2">
    The internal mechanics that make graph-based state management possible.
  </p>

  <hr />

  <h2>The Excel Insight</h2>

  <p>The best mental model for graph-based state management is something that has existed since the 1980s: <strong>a spreadsheet</strong>.</p>

  <p>An Excel spreadsheet is a massive grid of cells. Each cell is either a <strong>stored value</strong> (you type a number) or a <strong>computed value</strong> (a formula like <code>=A1+B1</code>). When you change a stored cell, every formula that depends on it automatically updates. The spreadsheet engine knows the dependency graph and recomputes only what's needed.</p>

  <Code code={excelCode} lang="swift" />

  <p>This is exactly what graph-based state management does. An application's entire state — no matter how complex — can be modeled as stored values and computed values with dependencies between them. The engine that powers Excel's cell updates is, in essence, the same engine that powers SwiftUI's view updates, Jotai's atom graph, and swift-state-graph's node system.</p>

  <p>The algorithms behind this aren't new. SwiftUI's AttributedGraph is based on academic papers from the 1970s and 1980s. Nothing in this space is truly novel — it's established computer science being applied to UI frameworks.</p>

  <hr />

  <h2>Only Two Primitives Exist</h2>

  <p>At the most fundamental level, every value in a state management system is one of exactly <strong>two things</strong>:</p>

  <ol>
    <li><strong>Stored</strong> — holds a concrete value directly (user input, API response, initial state)</li>
    <li><strong>Computed</strong> — derives its value from other nodes (always read-only, always dependent)</li>
  </ol>

  <Code code={twoKindsCode} lang="swift" />

  <p>This maps directly to every library covered in this report:</p>

  <div class="not-prose my-6 w-full overflow-auto rounded-lg border border-border bg-card">
    <table class="w-full min-w-[500px] caption-bottom text-sm">
      <thead class="[&_tr]:border-b">
        <tr class="border-b transition-colors">
          <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Library</th>
          <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Stored</th>
          <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Computed</th>
        </tr>
      </thead>
      <tbody class="[&_tr:last-child]:border-0">
        <tr class="border-b transition-colors hover:bg-muted/50">
          <td class="p-4 align-middle font-medium text-foreground">Excel</td>
          <td class="p-4 align-middle text-muted-foreground">Cell with a value</td>
          <td class="p-4 align-middle text-muted-foreground">Cell with a formula</td>
        </tr>
        <tr class="border-b transition-colors hover:bg-muted/50">
          <td class="p-4 align-middle font-medium text-foreground">swift-state-graph</td>
          <td class="p-4 align-middle text-muted-foreground">@GraphStored</td>
          <td class="p-4 align-middle text-muted-foreground">@GraphComputed</td>
        </tr>
        <tr class="border-b transition-colors hover:bg-muted/50">
          <td class="p-4 align-middle font-medium text-foreground">Jotai</td>
          <td class="p-4 align-middle text-muted-foreground">atom(value)</td>
          <td class="p-4 align-middle text-muted-foreground">atom(get =&gt; ...)</td>
        </tr>
        <tr class="border-b transition-colors hover:bg-muted/50">
          <td class="p-4 align-middle font-medium text-foreground">Atoms</td>
          <td class="p-4 align-middle text-muted-foreground">StateAtom</td>
          <td class="p-4 align-middle text-muted-foreground">ValueAtom</td>
        </tr>
        <tr class="border-b transition-colors hover:bg-muted/50">
          <td class="p-4 align-middle font-medium text-foreground">Riverpod</td>
          <td class="p-4 align-middle text-muted-foreground">NotifierProvider</td>
          <td class="p-4 align-middle text-muted-foreground">Provider</td>
        </tr>
        <tr class="border-b transition-colors hover:bg-muted/50">
          <td class="p-4 align-middle font-medium text-foreground">SwiftUI</td>
          <td class="p-4 align-middle text-muted-foreground">@State</td>
          <td class="p-4 align-middle text-muted-foreground">body (View)</td>
        </tr>
        <tr class="transition-colors hover:bg-muted/50">
          <td class="p-4 align-middle font-medium text-foreground">TanStack Store</td>
          <td class="p-4 align-middle text-muted-foreground">Store</td>
