---
import DocsLayout from '../layouts/DocsLayout.astro';
import { Code } from 'astro:components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const vergeDoubledCode = `// Verge — Push, explicit derived
let store = Store<MyState, Never>(initialState: .init())

let doubled = store.derived(.map(\\.count).map { $0 * 2 })

store.commit { $0.count = 5 }
// doubled pushes 10 to subscribers`;

const tcaDoubledCode = `// TCA — Push, computed property on State
@Reducer
struct Feature {
  @ObservableState
  struct State: Equatable {
    var count = 0
    var doubled: Int { count * 2 }  // plain computed
  }

  enum Action { case increment }

  var body: some ReducerOf<Self> {
    Reduce { state, action in
      switch action {
      case .increment:
        state.count += 1
        return .none
      }
    }
  }
}`;

const atomsDoubledCode = `// Atoms — Push + implicit graph
struct CountAtom: StateAtom, Hashable {
  func defaultValue(context: Context) -> Int { 0 }
}

struct DoubledAtom: ValueAtom, Hashable {
  func value(context: Context) -> Int {
    context.watch(CountAtom()) * 2  // auto-tracked, push-propagated
  }
}`;

const zustandDoubledCode = `// Zustand — Push, selector-based
const useStore = create((set) => ({
  count: 0,
  increment: () => set((s) => ({ count: s.count + 1 })),
}));

// Derived via selector (no graph)
function Doubled() {
  const doubled = useStore((s) => s.count * 2);
  return <span>{doubled}</span>;
}`;

const tanstackDoubledCode = `// TanStack Store — Push + explicit graph
const countStore = new Store(0);

const doubled = new Derived({
  deps: [countStore],
  fn: ({ currDepVals: [count] }) => count * 2,
});`;

const jotaiDoubledCode = `// Jotai — Pull, auto-tracked
const countAtom = atom(0);

const doubledAtom = atom((get) => get(countAtom) * 2);
// dependency on countAtom registered via get()`;

const ssgDoubledCode = `// swift-state-graph — Pull, DAG-based
struct MyGraph {
  @Stored var count: Int = 0

  @Computed var doubled: Int {
    count * 2  // auto-tracked via ThreadLocal
  }
}`;

const composeDoubledCode = `// Compose derivedStateOf — Pull, Snapshot system
@Composable
fun DoubledDisplay(viewModel: MyViewModel) {
  val count by viewModel.count.collectAsState()

  val doubled by remember {
    derivedStateOf { count * 2 }
  }

  Text("Doubled: $doubled")
}`;

const riverpodDoubledCode = `// Riverpod — Push + implicit graph
final countProvider = StateProvider((ref) => 0);

final doubledProvider = Provider((ref) {
  final count = ref.watch(countProvider);
  return count * 2;  // ref.watch() auto-registers dependency
});`;
