---
import DocsLayout from '../layouts/DocsLayout.astro';
import { Code } from 'astro:components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const viewModelCode = `class CounterViewModel : ViewModel() {
  private val _count = MutableStateFlow(0)
  val count: StateFlow<Int> = _count.asStateFlow()

  private val _multiplier = MutableStateFlow(2)
  val multiplier: StateFlow<Int> = _multiplier.asStateFlow()

  // Derived state via combine() — manual wiring
  val result: StateFlow<Int> = combine(
    _count, _multiplier
  ) { count, mult ->
    count * mult
  }.stateIn(
    scope = viewModelScope,
    started = SharingStarted.WhileSubscribed(5000),
    initialValue = 0
  )

  fun increment() {
    _count.value++
  }

  fun setMultiplier(value: Int) {
    _multiplier.value = value
  }
}`;

const viewModelViewCode = `@Composable
fun CounterScreen(viewModel: CounterViewModel = viewModel()) {
  val count by viewModel.count.collectAsState()
  val result by viewModel.result.collectAsState()

  Column {
    Text("Count: $count")
    Text("Result: $result")
    Button(onClick = { viewModel.increment() }) {
      Text("+")
    }
  }
}`;

const derivedStateCode = `@Composable
fun FilteredList(viewModel: ListViewModel) {
  val items by viewModel.items.collectAsState()
  val query by viewModel.query.collectAsState()

  // Pull-based: Snapshot system tracks reads
  val filteredItems by remember {
    derivedStateOf {
      if (query.isBlank()) items
      else items.filter { it.name.contains(query, ignoreCase = true) }
    }
  }

  // Only recomposes when filteredItems actually changes
  LazyColumn {
    items(filteredItems) { item ->
      Text(item.name)
    }
  }
}`;

const derivedStateExplainCode = `// How derivedStateOf works under the hood:
//
// 1. Creates a DerivedSnapshotState object
// 2. During first evaluation, Snapshot system records all
//    State<T> reads (items, query in the example above)
// 3. On subsequent frames, Compose checks:
//    a. Did any recorded source states change?
//       -> No: skip entirely (cheap check)
//       -> Yes: re-evaluate the block
//    b. Did the result change?
//       -> No: don't recompose readers
//       -> Yes: recompose affected Composables
//
// This two-level check prevents unnecessary recomposition
// even when source data changes but derived result is stable`;

const reactiveStateCode = `// ReactiveState-Kotlin: graph-based for business logic
class ShoppingCartModel {
  val items = reactiveState(listOf<CartItem>())
  val taxRate = reactiveState(0.08)

  val subtotal = derived {
    get(items).sumOf { it.price * it.quantity }
  }

  val tax = derived {
    get(subtotal) * get(taxRate)
  }

  val total = derived {
    get(subtotal) + get(tax)
  }

  fun addItem(item: CartItem) {
    items.value = items.value + item
    // subtotal, tax, and total all update automatically
  }
}`;

const reactiveStateObserveCode = `// Observing in Android
class CartActivity : AppCompatActivity() {
  private val model = ShoppingCartModel()

  override fun onCreate(savedInstanceState: Bundle?) {
    super.onCreate(savedInstanceState)

    // Observe derived state changes
    model.total.observe { total ->
      totalTextView.text = "Total: " + total
    }

    // Works with Compose too
    // val total by model.total.collectAsState()
  }
}`;

const reactiveStateKmpCode = `// Kotlin Multiplatform: share state logic
// commonMain/
class CounterModel {
  val count = reactiveState(0)
  val doubled = derived { get(count) * 2 }
  fun increment() { count.value++ }
}

// androidMain/ — use in ViewModel
// iosMain/   — bridge to Swift via KMP`;
