---
import DocsLayout from '../layouts/DocsLayout.astro';
import { Code } from 'astro:components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const riverpodBasicCode = `final counterProvider = NotifierProvider<Counter, int>(() => Counter());

class Counter extends Notifier<int> {
  @override
  int build() => 0;

  void increment() => state++;
}`;

const riverpodDerivedCode = `final doubledProvider = Provider((ref) {
  final count = ref.watch(counterProvider);
  return count * 2;  // ref.watch() auto-registers dependency
});

// Async derived provider
final userProvider = FutureProvider((ref) async {
  final id = ref.watch(userIdProvider);
  return await fetchUser(id);
});`;

const riverpodWidgetCode = `class CounterWidget extends ConsumerWidget {
  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final count = ref.watch(counterProvider);
    final doubled = ref.watch(doubledProvider);
    return Column(
      children: [
        Text('\$count (doubled: \$doubled)'),
        ElevatedButton(
          onPressed: () => ref.read(counterProvider.notifier).increment(),
          child: const Text('+'),
        ),
      ],
    );
  }
}`;

const riverpodScopeCode = `// ProviderScope wraps the app to hold provider state
void main() {
  runApp(
    ProviderScope(
      child: MyApp(),
    ),
  );
}

// ProviderScope can also override providers for testing
ProviderScope(
  overrides: [
    counterProvider.overrideWith(() => MockCounter()),
  ],
  child: MyApp(),
)`;

const riverpodFamilyCode = `// .family modifier for parameterized providers
final userProvider = FutureProvider.family<User, int>((ref, userId) async {
  return await fetchUser(userId);
});

// Usage in widget
final user = ref.watch(userProvider(42));`;

const providerLegacyCode = `// Provider (legacy) — InheritedWidget wrapper
class Counter with ChangeNotifier {
  int _count = 0;
  int get count => _count;

  void increment() {
    _count++;
    notifyListeners();  // push notification
  }
}

// Usage
ChangeNotifierProvider(
  create: (_) => Counter(),
  child: Consumer<Counter>(
    builder: (context, counter, _) => Text('\${counter.count}'),
  ),
)`;

const blocCode = `// BLoC — event-driven state management
class CounterBloc extends Bloc<CounterEvent, int> {
  CounterBloc() : super(0) {
    on<Increment>((event, emit) => emit(state + 1));
    on<Decrement>((event, emit) => emit(state - 1));
  }
}

// Usage with BlocBuilder
BlocBuilder<CounterBloc, int>(
  builder: (context, count) => Text('\$count'),
)`;
---

<DocsLayout title="Flutter Platform" currentPath={`${base}/flutter/`}>
  <h1>Flutter Platform</h1>
  <p class="text-lg text-muted-foreground !mt-2">
    State management in Flutter, from Provider to Riverpod's graph-based approach.
  </p>

  <hr />

  <h2>Context</h2>

  <p>Flutter's widget tree is inherently reactive: widgets rebuild when their state changes. The framework provides basic state primitives (<code>setState</code>, <code>InheritedWidget</code>), but most non-trivial apps need a dedicated state management solution.</p>

  <p>The Flutter state management landscape has evolved through several phases:</p>

  <ol>
    <li><strong>Provider (2019):</strong> A wrapper around <code>InheritedWidget</code>, recommended by the Flutter team. Push-based with <code>ChangeNotifier</code>.</li>
    <li><strong>BLoC (2018):</strong> Event-driven, stream-based pattern. Popular in enterprise Flutter apps.</li>
    <li><strong>GetX (2020):</strong> All-in-one solution with reactive state, routing, and DI. Controversial for mixing concerns.</li>
    <li><strong>Riverpod (2020):</strong> Created by the same author as Provider (Remi Rousselet), Riverpod fixes Provider's limitations with compile-safe, graph-based state management.</li>
  </ol>

  <p>Among these, <strong>Riverpod stands out as the most graph-like approach</strong> &mdash; it builds an implicit dependency graph via <code>ref.watch()</code> with push-based propagation, making it architecturally similar to Atoms (swiftui-atom-properties) in the iOS ecosystem.</p>

  <hr />

  <!-- Riverpod -->
  <h2 id="riverpod">Riverpod</h2>
  <p class="not-prose text-sm text-muted-foreground"><a href="https://github.com/rrousselGit/riverpod" class="underline underline-offset-4 hover:text-foreground">github.com/rrousselGit/riverpod</a></p>

  <p><strong>Paradigm:</strong> Push + Implicit Graph &nbsp;|&nbsp; <strong>Status:</strong> Dominant graph-based solution</p>

  <p>Riverpod is a reactive state management library for Flutter that uses "providers" as atomic units of state. Dependencies are tracked automatically via <code>ref.watch()</code> &mdash; the act of watching a provider registers a dependency edge in the graph. When a source provider changes, all dependent providers are eagerly recomputed (push-based propagation).</p>

  <h3>How ref.watch() Works</h3>

  <p>The core mechanism is simple: when a provider's build function calls <code>ref.watch(otherProvider)</code>, it:</p>
  <ol>
    <li>Reads the current value of <code>otherProvider</code></li>
    <li>Registers a dependency: "this provider depends on otherProvider"</li>
    <li>When <code>otherProvider</code> changes, this provider is marked for rebuild</li>
  </ol>

  <p>This is the same implicit tracking pattern as Jotai's <code>get()</code> and Atoms' <code>context.watch()</code>, but with push-based update propagation.</p>

