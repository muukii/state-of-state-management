---
interface Props {
  title: string;
  description: string;
}

import '../styles/global.css';

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const favicon = `${base.replace(/\/$/, '')}/favicon.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <script is:inline>
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches))
        document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="min-h-screen bg-background font-sans text-foreground antialiased">
    <slot />
    <script is:inline type="module">
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

      const resolve = (name) => {
        const val = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
        return val ? `hsl(${val})` : '';
      };

      const render = () => {
        const isDark = document.documentElement.classList.contains('dark');
        const bg = resolve('--background');
        const fg = resolve('--foreground');
        const muted = resolve('--muted');
        const mutedFg = resolve('--muted-foreground');
        const border = resolve('--border');

        mermaid.initialize({
          startOnLoad: false,
          theme: 'base',
          themeVariables: {
            darkMode: isDark,
            background: bg,
            primaryColor: muted,
            primaryTextColor: fg,
            primaryBorderColor: border,
            lineColor: mutedFg,
            secondaryColor: muted,
            tertiaryColor: muted,
            fontFamily: 'JetBrains Mono, ui-monospace, monospace',
            fontSize: '13px',
          },
        });

        document.querySelectorAll('.mermaid').forEach((el) => {
          el.removeAttribute('data-processed');
          if (el.dataset.source) el.textContent = el.dataset.source;
          else el.dataset.source = el.textContent;
        });
        mermaid.run({ querySelector: '.mermaid' });
      };

      render();
      new MutationObserver(render).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });
    </script>
  </body>
</html>
