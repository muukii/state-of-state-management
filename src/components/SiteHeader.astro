---
import Button from './ui/Button.astro';
import ThemeToggle from './ui/ThemeToggle.astro';
---

<header class="sticky top-0 z-40 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="mx-auto flex h-14 max-w-screen-2xl items-center px-4 sm:px-6 lg:px-8">
    <a href="#" class="flex items-center gap-2 mr-6">
      <svg class="h-5 w-5 text-foreground" viewBox="0 0 64 64" fill="none" aria-hidden="true">
        <circle cx="20" cy="32" r="6" fill="currentColor"/>
        <circle cx="44" cy="16" r="6" fill="currentColor" opacity="0.6"/>
        <circle cx="44" cy="48" r="6" fill="currentColor" opacity="0.4"/>
        <line x1="25" y1="29" x2="39" y2="18" stroke="currentColor" stroke-width="2" opacity="0.3"/>
        <line x1="25" y1="35" x2="39" y2="46" stroke="currentColor" stroke-width="2" opacity="0.3"/>
      </svg>
      <span class="font-semibold tracking-tight text-sm">State of State Management</span>
    </a>
    <div class="flex flex-1 items-center justify-end gap-1">
      <Button
        href="https://github.com/muukii"
        variant="ghost"
        size="icon"
        ariaLabel="GitHub"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-[1.2rem] w-[1.2rem]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </Button>
      <ThemeToggle />
    </div>
  </div>
</header>
