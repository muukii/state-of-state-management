---
---

<!-- Top bar -->
<div class="topbar">
  <div class="flex items-center gap-2">
    <button id="theme-light" class="p-1.5 rounded-md text-neutral-400 dark:text-neutral-500 hover:text-neutral-600 dark:hover:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all" aria-label="Light theme">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
    </button>
    <button id="theme-dark" class="p-1.5 rounded-md text-neutral-400 dark:text-neutral-500 hover:text-neutral-600 dark:hover:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all" aria-label="Dark theme">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
    </button>
  </div>
</div>

<!-- Hero (centered) -->
<header class="lg:ml-[200px] pt-28 pb-16 sm:pt-36 sm:pb-24">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <h1 class="text-[2.5rem] sm:text-[3.25rem] font-bold leading-[1.08] tracking-tight text-neutral-900 dark:text-neutral-100">
      State of<br />State Management
    </h1>
    <p class="mt-5 text-base sm:text-lg text-neutral-400 dark:text-neutral-500 leading-relaxed max-w-md mx-auto">
      The rise of graph-based approaches across Web, iOS, and Android.
    </p>
    <div class="mt-6 text-[13px] text-neutral-300 dark:text-neutral-600">
      Last updated Mar 2026
    </div>
  </div>
</header>

<script>
  document.getElementById('theme-light')?.addEventListener('click', () => {
    document.documentElement.classList.remove('dark');
    localStorage.setItem('theme', 'light');
  });
  document.getElementById('theme-dark')?.addEventListener('click', () => {
    document.documentElement.classList.add('dark');
    localStorage.setItem('theme', 'dark');
  });
</script>
