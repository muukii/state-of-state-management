---
interface Props {
  chart: string;
  class?: string;
}

const { chart, class: className = '' } = Astro.props;
const id = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<div class:list={['mermaid-diagram overflow-hidden rounded-md bg-muted p-4', className]}>
  <pre class="mermaid" id={id} set:text={chart.trim()} />
</div>

<style>
  .mermaid-diagram :global(.mermaid) {
    display: flex;
    justify-content: center;
    background: transparent;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .mermaid-diagram :global(.mermaid svg) {
    max-width: 100%;
    height: auto;
  }
</style>
