---
interface Props {
  chart: string;
  class?: string;
}

const { chart, class: className = '' } = Astro.props;
const id = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<div class:list={["mermaid-diagram rounded-xl overflow-hidden border border-neutral-200/60 dark:border-neutral-800/60 bg-[#0c0c0c] p-6", className]}>
  <pre class="mermaid" id={id} set:text={chart.trim()} />
</div>

<style>
  .mermaid-diagram :global(.mermaid) {
    display: flex;
    justify-content: center;
    background: transparent;
    font-family: monospace;
  }
  .mermaid-diagram :global(.mermaid svg) {
    max-width: 100%;
    height: auto;
  }
</style>
