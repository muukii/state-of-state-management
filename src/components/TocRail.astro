---
interface Props {
  sections: { id: string; title: string }[];
}
const { sections } = Astro.props;
---

<aside class="hidden xl:block w-48 shrink-0">
  <div class="sticky top-16 -mt-6 pt-6">
    <div class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
      Contents
    </div>
    <ul class="flex flex-col gap-2 border-l border-border">
      {sections.map(({ id, title }) => (
        <li>
          <a
            href={`#${id}`}
            class="block border-l border-transparent -ml-px pl-4 py-0.5 text-xs text-muted-foreground transition-colors hover:text-foreground"
          >
            {title}
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>
