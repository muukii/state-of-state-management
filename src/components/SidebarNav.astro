---
interface Props {
  sections: { id: string; title: string }[];
}
const { sections } = Astro.props;
---

<aside class="hidden lg:block sticky top-14 h-[calc(100vh-3.5rem)] w-56 shrink-0 overflow-y-auto border-r border-border/40 py-6 pr-4">
  <div class="mb-4 px-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
    On this page
  </div>
  <nav id="sidebar-nav">
    <ul class="flex flex-col gap-1">
      {sections.map(({ id, title }) => (
        <li>
          <a
            href={`#${id}`}
            data-toc-link={id}
            class="toc-link flex w-full items-center rounded-md px-2 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground hover:bg-accent"
          >
            {title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  :global(.toc-link.active) {
    @apply bg-accent text-foreground font-medium;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          document.querySelectorAll('.toc-link').forEach((l) => l.classList.remove('active'));
          document
            .querySelector(`.toc-link[data-toc-link="${entry.target.id}"]`)
            ?.classList.add('active');
        }
      });
    },
    { rootMargin: '-10% 0px -80% 0px' }
  );
  document.querySelectorAll('section[id]').forEach((s) => observer.observe(s));
</script>
